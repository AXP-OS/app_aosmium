+package org.chromium.components.browser_ui.site_settings;
+
+import androidx.preference.Preference;
+
+import org.chromium.build.annotations.AlwaysInline;
+import org.chromium.build.annotations.NonNull;
+import org.chromium.build.annotations.NullMarked;
+import org.chromium.build.annotations.Nullable;
+import org.chromium.components.browser_ui.settings.ChromeBasePreference;
+import org.chromium.components.content_settings.ContentSetting;
+import org.chromium.components.content_settings.ContentSettingsType;
+import org.chromium.content_public.browser.BrowserContextHandle;
+
+@NullMarked
+public final class JavascriptJitSettingsHooks {
+
+    @NonNull
+    @AlwaysInline
+    private static String commonPrefKey() {
+        return "javascript_jit";
+    }
+
+    static final class ResourcesHooksImpl extends SiteSettingsResourcesHooks {
+
+        @Override
+        public int getIconRes() {
+            return R.drawable.settings_v8;
+        }
+
+        @Override
+        public int getIconBlockedRes() {
+            return 0;
+        }
+
+        @Override
+        public int getTitleRes() {
+            return R.string.javascript_jit_permission_title;
+        }
+
+        @Override
+        @ContentSetting
+        public int getDefaultEnabledValue() {
+            return ContentSetting.ALLOW;
+        }
+
+        @Override
+        @ContentSetting
+        public int getDefaultDisabledValue() {
+            return ContentSetting.BLOCK;
+        }
+
+        @Override
+        public int getEnabledSummaryRes() {
+            return R.string.website_settings_category_javascript_jit_allowed;
+        }
+
+        @Override
+        public int getDisabledSummaryRes() {
+            return R.string.website_settings_category_javascript_jit_blocked;
+        }
+
+        @Override
+        public int getSummaryOverrideForScreenReaderRes() {
+            return 0;
+        }
+
+        @Override
+        public int getEnabledPrimaryTextRes() {
+            return R.string.website_settings_javascript_jit_allow;
+        }
+
+        @Override
+        public int getDisabledPrimaryTextRes() {
+            return R.string.website_settings_javascript_jit_block;
+        }
+
+        @Override
+        public int getDisabledDescriptionTextRes() {
+            return super.getDisabledDescriptionTextRes();
+        }
+    }
+
+    static final class CategoryHooksImpl extends SiteSettingsCategoryHooks {
+
+        @Override
+        protected @NonNull String getPreferenceKey() {
+            return commonPrefKey();
+        }
+
+        @Override
+        protected int getContentSettingsType() {
+            return ContentSettingsType.JAVASCRIPT_JIT;
+        }
+
+        @Override
+        @NonNull
+        protected SiteSettingsCategory getSiteSettingsCategory(@NonNull BrowserContextHandle bch) {
+            return new SiteSettingsCategory(bch, SiteSettingsCategory.Type.JAVASCRIPT_JIT, "");
+        }
+    }
+
+    static final class SiteSettingsScreenHooksImpl extends SiteSettingsScreenHooks {
+
+        @Override
+        protected int getPreviousContentSettings() {
+            return ContentSettingsType.JAVASCRIPT;
+        }
+
+        @Override
+        protected void configureSiteSettingsPreference(
+                @NonNull SiteSettings siteSettingsFragment,
+                @NonNull SiteSettingsDelegate siteSettingsDelegate,
+                @SiteSettingsCategory.Type int categoryType,
+                @Nullable Preference existingPreference) {
+            ChromeBasePreference pref = defaultCreatePreference(siteSettingsFragment, commonPrefKey());
+            addPreference(siteSettingsFragment, siteSettingsDelegate, categoryType, pref);
+        }
+    }
+
+    static final class WebsitePermissionsFetcherHooksImpl extends WebsitePermissionsFetcherHooks {
+
+        @Override
+        protected int getPermissionTypeOverride() {
+            return CONTENT_SETTING_EXCEPTION;
+        }
+
+        @Override
+        protected boolean shouldCreateExceptionIfNull() {
+            return true;
+        }
+    }
+
+    static final class SingleCategorySettingsHooksImpl extends SingleCategorySettingsHooks {
+
+        @Override
+        protected int getGlobalToggleLayoutOverride() {
+            return NONE;
+        }
+
+        @Override
+        protected @Nullable Boolean shouldAddExceptionButton(boolean isCategoryEnabled) {
+            return true;
+        }
+
+        @Override
+        protected int getAddExceptionDialogMessageResourceId(boolean isCategoryEnabled) {
+            return isCategoryEnabled ? R.string.website_settings_add_site_description_javascript_jit_block
+                                     : R.string.website_settings_add_site_description_javascript_jit_allow;
+        }
+    }
+
+    static final class SingleWebsiteSettingsHooksImpl extends SingleWebsiteSettingsHooks {
+        @Override
+        protected @NonNull String getPreferenceKey() {
+            return commonPrefKey() + "_permission_list";
+        }
+
+        @Override
+        protected @Nullable Integer getContentSettingForSetup(
+                @NonNull BrowserContextHandle browserContextHandle,
+                @NonNull Website website,
+                @ContentSettingsType.EnumType int contentType) {
+            Integer curValue = website.getContentSetting(browserContextHandle, contentType);
+            if (curValue == null) {
+                boolean isEnabled = WebsitePreferenceBridge.isContentSettingEnabled(browserContextHandle, contentType);
+                curValue = isEnabled ? ContentSetting.ALLOW : ContentSetting.BLOCK;
+            }
+            return curValue;
+        }
+    }
+}
